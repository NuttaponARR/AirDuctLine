# Copy this file to .env.line and fill the real values.
# Do not commit .env.line.

LIFF_ID=your-liff-id
LINE_APP_URL=https://your-public-https-domain.example
PORT=8765
HOST=0.0.0.0

# Only needed if you also connect a LINE Messaging API channel (webhook).
# From LINE Developers > Messaging API channel.
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
